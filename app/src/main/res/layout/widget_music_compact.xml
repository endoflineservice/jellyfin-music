<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_compact_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:contentDescription="@string/widget_music_compact_description"
        android:src="@drawable/widget_vinyl" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Jellyfin Music"
            android:textColor="#FEF7FF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Tap to open"
            android:textColor="#E9DDFF"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="18"
            android:progressDrawable="@drawable/widget_progress" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_previous"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/widget_next"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="invisible" />

    <TextView
        android:id="@+id/widget_play"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/widget_play_button"
        android:gravity="center"
        android:text=">"
        android:textColor="#3C354B"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
