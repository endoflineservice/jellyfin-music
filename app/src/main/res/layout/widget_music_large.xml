<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <ImageView
        android:id="@+id/widget_album"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.15"
        android:contentDescription="@string/widget_music_card_description"
        android:scaleType="fitCenter"
        android:src="@drawable/widget_vinyl" />

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="14dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Jellyfin Music"
            android:textColor="@color/widget_on_surface"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/widget_title"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Tap to open"
            android:textColor="@color/widget_on_surface_variant"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/widget_controls"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/widget_previous"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/widget_control_button"
                android:contentDescription="Previous"
                android:padding="12dp"
                android:scaleType="center"
                android:src="@drawable/widget_icon_previous" />

            <ImageView
                android:id="@+id/widget_play"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/widget_play_button"
                android:contentDescription="Play or pause"
                android:padding="15dp"
                android:scaleType="center"
                android:src="@drawable/widget_icon_play" />

            <ImageView
                android:id="@+id/widget_next"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/widget_control_button"
                android:contentDescription="Next"
                android:padding="12dp"
                android:scaleType="center"
                android:src="@drawable/widget_icon_next" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_above="@id/widget_controls"
            android:layout_marginBottom="12dp"
            android:indeterminate="false"
            android:max="1000"
            android:progress="180"
            android:progressDrawable="@drawable/widget_progress" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible" />
    </RelativeLayout>
</LinearLayout>
