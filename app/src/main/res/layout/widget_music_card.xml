<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <FrameLayout
        android:layout_width="118dp"
        android:layout_height="118dp">

        <ImageView
            android:id="@+id/widget_album"
            android:layout_width="118dp"
            android:layout_height="118dp"
            android:contentDescription="@string/widget_music_card_description"
            android:src="@drawable/widget_vinyl" />

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:background="@drawable/widget_label_dot"
            android:gravity="center"
            android:text="JM"
            android:textColor="#FDF8FF"
            android:textSize="9sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="14dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Jellyfin Music"
            android:textColor="#FEF7FF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Tap to open"
            android:textColor="#E9DDFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/widget_status_pill"
            android:gravity="center"
            android:minWidth="88dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Ready"
            android:textColor="#FDF8FF"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="14dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="18"
            android:progressDrawable="@drawable/widget_progress" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_previous"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="|&lt;"
                android:textColor="#FDF8FF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_play"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:background="@drawable/widget_play_button"
                android:gravity="center"
                android:text=">"
                android:textColor="#3C354B"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="&gt;|"
                android:textColor="#FDF8FF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
